# FlavorFlow API — copy to server/.env
# JWT must be ≥32 chars in production.

PORT=8787
DATABASE_URL=postgresql://flavorflow:flavorflow@localhost:5432/flavorflow
JWT_SECRET=please-replace-with-at-least-thirty-two-random-characters
REDIS_URL=redis://127.0.0.1:6379

# Comma-separated OAuth client IDs (must match IDs that mint Google id_tokens — same family as EXPO_PUBLIC_*).
GOOGLE_OAUTH_CLIENT_IDS=
