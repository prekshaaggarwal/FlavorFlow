# FlavorFlow (Expo) — copy to .env at repo root, then restart `npx expo start`
# https://docs.expo.dev/guides/environment-variables/

# Backend used by OTP + restaurant APIs (omit trailing slash)
EXPO_PUBLIC_API_URL=http://localhost:8787

# Google Sign-In — OAuth 2.0 client IDs from Google Cloud Console → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Optional native (recommended for iOS/Android release builds):
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# Extra client ID if Expo proxy / dev client expects a separate audience:
# EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
